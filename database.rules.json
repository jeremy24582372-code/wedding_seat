{
  "rules": {
    ".read": false,
    ".write": false,
    "wedding-seating": {
      ".read": true,
      ".write": "newData.exists()",
      ".validate": "newData.hasChild('tables') && newData.hasChild('lastSaved')",
      "guests": {
        "$guestIndex": {
          ".validate": "newData.hasChildren(['id', 'name', 'category', 'diet', 'source'])",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "category": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
          },
          "diet": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          },
          "source": {
            ".validate": "newData.isString() && (newData.val() === 'manual' || newData.val() === 'import')"
          },
          "tableId": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "partyId": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "partyRole": {
            ".validate": "newData.isString() && (newData.val() === 'primary' || newData.val() === 'companion')"
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "partyRows": {
        "$partyIndex": {
          ".validate": "newData.hasChildren(['id', 'sourceName', 'category', 'headcount', 'guestIds', 'source'])",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "sourceName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "category": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
          },
          "tableLabel": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "headcount": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10"
          },
          "guestIds": {
            "$guestIndex": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            }
          },
          "source": {
            ".validate": "newData.isString() && (newData.val() === 'manual' || newData.val() === 'import')"
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "guestGroups": {
        "$groupIndex": {
          ".validate": "newData.hasChildren(['id', 'name', 'guestIds', 'preference', 'locked', 'notes'])",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "guestIds": {
            "$guestIndex": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            }
          },
          "sourcePartyId": {
            ".validate": "newData.isString() && newData.val().length <= 80"
          },
          "preference": {
            ".validate": "newData.isString() && (newData.val() === 'same-table' || newData.val() === 'nearby' || newData.val() === 'separate')"
          },
          "locked": {
            ".validate": "newData.isBoolean()"
          },
          "notes": {
            ".validate": "newData.isString() && newData.val().length <= 200"
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "tables": {
        "$tableIndex": {
          ".validate": "newData.hasChildren(['id', 'label', 'seats'])",
          "id": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          },
          "label": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
          },
          "seats": {
            ".validate": "newData.isNumber() && newData.val() === 10"
          },
          "guestIds": {
            "$seatIndex": {
              ".validate": "($seatIndex === '0' || $seatIndex === '1' || $seatIndex === '2' || $seatIndex === '3' || $seatIndex === '4' || $seatIndex === '5' || $seatIndex === '6' || $seatIndex === '7' || $seatIndex === '8' || $seatIndex === '9') && newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            }
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "unassignedGuestIds": {
        "$guestIndex": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        }
      },
      "tablePositions": {
        "$tableId": {
          ".validate": "newData.hasChildren(['x', 'y'])",
          "x": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3000"
          },
          "y": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3000"
          },
          "$other": {
            ".validate": false
          }
        }
      },
      "seatingRules": {
        ".validate": "newData.hasChildren(['fillStrategy', 'respectExistingAssignments', 'preferFillIncompleteTables', 'keepGroupsTogether'])",
        "fillStrategy": {
          ".validate": "newData.isString() && (newData.val() === 'balanced' || newData.val() === 'category-first' || newData.val() === 'keep-existing')"
        },
        "respectExistingAssignments": {
          ".validate": "newData.isBoolean()"
        },
        "maxPerCategoryPerTable": {
          "$category": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 10"
          }
        },
        "preferFillIncompleteTables": {
          ".validate": "newData.isBoolean()"
        },
        "keepGroupsTogether": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      },
      "lockedAssignments": {
        "$guestId": {
          ".validate": "newData.isBoolean()"
        }
      },
      "lastSaved": {
        ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
      },
      "$other": {
        ".validate": false
      }
    }
  }
}
